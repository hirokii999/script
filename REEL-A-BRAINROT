local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Ultimate Farmer | v3.1",
   LoadingTitle = "Systems Optimized...",
})

local Tab = Window:CreateTab("Automation", 4483362458)

-- Variables
local autoCollect = false
local autoFish = false
local autoUpgrade = false
local autoSell = false
local autoEquip = false
local sellCooldown = 5 
local targetUpgrade = "power1"

-- 1. PLOT MANAGEMENT (COLLECT & EQUIP)
Tab:CreateSection("Plot Management")

Tab:CreateToggle({
   Name = "💰 Auto-Collect All Plots",
   CurrentValue = false,
   Callback = function(Value)
      autoCollect = Value
      task.spawn(function()
         while autoCollect do
            for i = 1, 10 do
               if not autoCollect then break end
               game:GetService("ReplicatedStorage"):WaitForChild("RemoteHandler"):WaitForChild("Collect"):FireServer("Plot" .. i)
               task.wait(0.05)
            end
            task.wait(0.5)
         end
      end)
   end,
})

Tab:CreateToggle({
   Name = "⚔️ Auto-Equip Best (5s Cycle)",
   CurrentValue = false,
   Callback = function(Value)
      autoEquip = Value
      task.spawn(function()
         while autoEquip do
            for i = 1, 10 do
               if not autoEquip then break end
               -- Arguments based on your provided remote structure
               local args = {"EquipBest", "Plot" .. i, "String"} 
               game:GetService("ReplicatedStorage"):WaitForChild("RemoteHandler"):WaitForChild("Plot"):FireServer(unpack(args))
               task.wait(0.05) -- Fast cycle through plots
            end
            task.wait(5) -- Reduced to 5 second wait between full cycles
         end
      end)
   end,
})

-- 2. SELLING
Tab:CreateSection("Selling")

Tab:CreateSlider({
   Name = "Sell Cooldown (Seconds)",
   Range = {1, 60},
   Increment = 1,
   Suffix = "s",
   CurrentValue = 5,
   Callback = function(Value)
      sellCooldown = Value
   end,
})

Tab:CreateToggle({
   Name = "⚖️ Auto-Sell Rarities",
   CurrentValue = false,
   Callback = function(Value)
      autoSell = Value
      local sellArgs = {{
         Legendary = true, Rare = true, Godly = true, 
         Epic = true, Mythic = true, Uncommon = true, Secret = true
      }}
      
      task.spawn(function()
         while autoSell do
            game:GetService("ReplicatedStorage"):WaitForChild("RemoteHandler"):WaitForChild("SellMultiple"):FireServer(unpack(sellArgs))
            task.wait(sellCooldown)
         end
      end)
   end,
})

-- 3. FISHING
Tab:CreateSection("Fishing")
Tab:CreateToggle({
   Name = "🎣 Auto-Fish/Reel (Fast)",
   CurrentValue = false,
   Callback = function(Value)
      autoFish = Value
      task.spawn(function()
         while autoFish do
            game:GetService("ReplicatedStorage"):WaitForChild("RemoteHandler"):WaitForChild("Fishing"):FireServer("Caught", 2)
            task.wait(0.2) -- Updated to 0.2s per reel
         end
      end)
   end,
})

-- 4. TARGETED UPGRADES
Tab:CreateSection("Targeted Upgrades")
Tab:CreateDropdown({
   Name = "Select Upgrade Tier",
   Options = {"power1", "power5", "power10"},
   CurrentOption = {"power1"},
   Callback = function(Option)
      targetUpgrade = Option[1]
   end,
})

Tab:CreateToggle({
   Name = "🚀 Auto-Upgrade Selected",
   CurrentValue = false,
   Callback = function(Value)
      autoUpgrade = Value
      task.spawn(function()
         while autoUpgrade do
            game:GetService("ReplicatedStorage"):WaitForChild("RemoteHandler"):WaitForChild("Upgrade"):FireServer(targetUpgrade)
            task.wait(0.1)
         end
      end)
   end,
})
