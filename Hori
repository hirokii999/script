-- [[ HARVEST LOGIC ]] --
local uuids = {
    "f2d8d2af-423e-4878-aac7-44abc6d6a5e6",
    "5e7d694c-28d2-41b4-be4c-4f18a854d311",
    "11128b77-faf0-470c-bd92-ee95dd607820",
    "2ff02819-7005-4e89-8e6a-9604fc59462e",
    "5abe9396-f517-4eb3-a5bc-fdadeee7d525"
}

local Remote = game:GetService("ReplicatedStorage"):WaitForChild("RemoteEvents"):WaitForChild("HarvestFruit")
local isRunning = false

local function startHarvesting()
    while isRunning do
        StatusLabel.Text = "Harvesting..."
        for _, id in ipairs(uuids) do
            if not isRunning then break end
            Remote:FireServer({{{ GrowthAnchorIndex = 1, Uuid = id }}})
            task.wait(0.1)
        end
        StatusLabel.Text = "Waiting for growth..."
        task.wait(5)
    end
end

ToggleBtn.MouseButton1Click:Connect(function()
    isRunning = not isRunning
    ToggleBtn.Text = isRunning and "ON" or "OFF"
    ToggleBtn.BackgroundColor3 = isRunning and Color3.fromRGB(60, 200, 60) or Color3.fromRGB(200, 60, 60)
    if isRunning then task.spawn(startHarvesting) end
end)

-- PRESS "INSERT" KEY TO HIDE/SHOW UI
game:GetService("UserInputService").InputBegan:Connect(function(input, processed)
    if not processed and input.KeyCode == Enum.KeyCode.Insert then
        MainFrame.Visible = not MainFrame.Visible
    end
end)
